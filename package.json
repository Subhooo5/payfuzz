{
  "name": "payfuzz",
  "version": "0.1.0",
  "description": "Asserts that a webhook handler cannot create or destroy money under adversarial delivery — not that it returns 200, but that the ledger balances.",
  "type": "module",
  "author": "Subhodeep",
  "license": "MIT",
  "homepage": "https://github.com/Subhooo5/payfuzz#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Subhooo5/payfuzz.git"
  },
  "bugs": {
    "url": "https://github.com/Subhooo5/payfuzz/issues"
  },
  "bin": {
    "payfuzz": "dist/cli.js"
  },
  "files": [
    "dist",
    "scenarios",
    "fixtures"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "node --import tsx --test test/signer.test.ts test/victims.test.ts",
    "victim:naive": "tsx victims/naive/index.ts",
    "victim:hardened": "tsx victims/hardened/index.ts",
    "capture:fixtures": "node scripts/capture-fixtures.mjs"
  },
  "keywords": [
    "stripe",
    "webhook",
    "testing",
    "idempotency",
    "payments",
    "fuzzing"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1",
    "stripe": "^22.3.1",
    "undici": "^7.28.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
